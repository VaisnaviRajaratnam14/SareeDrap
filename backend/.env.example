# ──────────────────────────────────────────────
#  SareeDrape Studio — Backend Environment
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────
# Option A: MongoDB Atlas (cloud — recommended)
#   1. Create free cluster at https://cloud.mongodb.com
#   2. Database Access → Add user (readWriteAnyDatabase)
#   3. Network Access → Add IP (0.0.0.0/0 for dev)
#   4. Clusters → Connect → Drivers → copy URI
#   5. Replace <username>, <password>, <cluster>
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/saree_draping_db?retryWrites=true&w=majority

# Option B: Local MongoDB
# MONGO_URI=mongodb://localhost:27017/saree_draping_db

# ── Security ───────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string

# ── JWT ────────────────────────────────────────
JWT_EXPIRY_HOURS=24

# ── Flask ──────────────────────────────────────
FLASK_DEBUG=true

# ── File storage ───────────────────────────────
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs

# ── CORS (comma-separated extra origins) ───────
# ALLOWED_ORIGINS=https://yourdomain.com

# ── Kaggle API credentials ──────────────────────
# 1. Go to https://www.kaggle.com → Account → Create API Token
# 2. Download kaggle.json — it contains {"username":"...","key":"..."}
# 3. Either place kaggle.json at C:\Users\<you>\.kaggle\kaggle.json
#    OR set these two env vars:
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
